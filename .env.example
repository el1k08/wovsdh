# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Google Calendar API (OAuth 2.0)
# Получить через: https://console.cloud.google.com/
# Инструкция: docs/GOOGLE_CALENDAR_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback
GOOGLE_REFRESH_TOKEN_RISHON=   # refresh token для студии Ришон-ле-Цион
GOOGLE_REFRESH_TOKEN_ASHDOD=   # refresh token для студии Ашдод
GOOGLE_CALENDAR_ID_RISHON=     # ID календаря для студии Ришон-ле-Цион
GOOGLE_CALENDAR_ID_ASHDOD=     # ID календаря для студии Ашдод

# SMTP (Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SECRET_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# SEO
GOOGLE_SITE_VERIFICATION=   # из Google Search Console
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=   # AW-XXXXXXXXXX/YYYYYYY из Google Ads
